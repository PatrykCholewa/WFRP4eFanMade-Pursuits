{"_id":"OpenChaseRollRq","name":"Popros o testy","type":"script","scope":"global","img":"icons/svg/dice-target.svg","command":"if (!game.user?.isGM) {\n  ui.notifications.warn(\"Tylko GM moze uruchomic to makro.\");\n  return;\n}\n\nif (!game.wfrpChase?.openRollRequestDialog) {\n  ui.notifications.error(\"Modul poscigow nie jest jeszcze gotowy.\");\n  return;\n}\n\ngame.wfrpChase.openRollRequestDialog();","folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"OpenChaseTrackr","name":"Zarzadzaj poscigiem","type":"script","scope":"global","img":"icons/svg/clockwork.svg","command":"if (!game.user?.isGM) {\n  ui.notifications.warn(\"Tylko GM moze uruchomic to makro.\");\n  return;\n}\n\nif (!game.wfrpChase?.openTracker) {\n  ui.notifications.error(\"Modul poscigow nie jest jeszcze gotowy.\");\n  return;\n}\n\ngame.wfrpChase.openTracker();","folder":null,"sort":1000,"ownership":{"default":0},"flags":{}}